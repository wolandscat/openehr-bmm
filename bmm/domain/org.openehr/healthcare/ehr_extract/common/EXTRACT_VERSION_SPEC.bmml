import org.openehr:representation ;
import org.openehr:foundation ;


|
| Specification of what versions should be included in an Extract. By default, only
| latest versions are included. The include_all_versions and commit_time_interval
| attributes are used to modify this behaviour.
|
class EXTRACT_VERSION_SPEC

feature_group ("access")

    |
    | True if all versions of each item in the Extract are included.
    |
    prop include_all_versions : Boolean ;

    |
    | Specifies commit time interval of items to source repository to include in Extract. By
    | default, only latest versions whose commit times fall in the range are included. If
    | include_all_versions is True, then the range includes all versions committed within the
    | interval.
    |
    prop commit_time_interval :? DV_INTERVAL<DV_DATE_TIME> ;

    |
    | True if revision histories of the items in the Extract are included. If included, it is
    | always the full revision history.
    |
    prop include_revision_history : Boolean ;

    |
    | `True` if the data of items matched by the content spec should be included. This is the
    | default. If `False`, only revision history is included in serialised versions. Turning
    | this option on in openEHR systems causes `X_VERSIONED_OBJECTs` to have
    | `_revision_history_` set, but versions Void. Useful for interrogating a server without
    | having to look at any content data. In other systems it may or may not have a sensible
    | meaning.
    |
    prop include_data : Boolean ;

invariant
    includes_revision_history_valid: ¬include_data ⇒ include_revision_history;

end