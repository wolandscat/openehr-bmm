import org.openehr:representation;

|
| Enumeration of transitions in the Instruction State Machine (ISM) that drive
| changes between instruction execution states.
|
enumeration INSTRUCTION_EXECUTION_TRANSITION
    base_type String

feature_group ("values")

    |
    | Transition to initiate an instruction.
    |
    ism_t_initiate ("initiate");

    |
    | Transition to start execution.
    |
    ism_t_start ("start");

    |
    | Transition to schedule the instruction.
    |
    ism_t_schedule ("schedule");

    |
    | Transition representing a planned step.
    |
    ism_t_plan_step ("plan_step");

    |
    | Transition to cancel the instruction.
    |
    ism_t_cancel ("cancel");

    |
    | Transition to perform an active step.
    |
    ism_t_do ("do");

    |
    | Transition to resume a suspended instruction.
    |
    ism_t_resume ("resume");

    |
    | Transition to suspend an active instruction.
    |
    ism_t_suspend ("suspend");

    |
    | Transition representing a step in suspended state.
    |
    ism_t_suspended_step ("suspended_step");

    |
    | Transition representing a step in active state.
    |
    ism_t_active_step ("active_step");

    |
    | Transition representing a step in scheduled state.
    |
    ism_t_scheduled_step ("scheduled_step");

    |
    | Transition representing a step in postponed state.
    |
    ism_t_postponed_step ("postponed_step");

    |
    | Transition to abort the instruction.
    |
    ism_t_abort ("abort");

    |
    | Transition to restore a previously suspended instruction.
    |
    ism_t_restore ("restore");

    |
    | Transition to postpone an instruction.
    |
    ism_t_postpone ("postpone");

    |
    | Transition triggered by expiry of a time limit.
    |
    ism_t_time_out ("time_out");

    |
    | Transition notifying that the instruction completed.
    |
    ism_t_notify_completed ("notify_completed");

    |
    | Transition notifying that the instruction was aborted.
    |
    ism_t_notify_aborted ("notify_aborted");

end
