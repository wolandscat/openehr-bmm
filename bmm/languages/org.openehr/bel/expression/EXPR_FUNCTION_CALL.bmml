import org.openehr:representation;

|
| Node representing a function call with 0 or more arguments. Functions with no arguments
| are typically used to represent real world varying values like 'current time'.
|
class EXPR_FUNCTION_CALL
    is_a EXPR_LEAF

feature_group ("access")

    |
    | Arguments of this function, which can be from 0 to any number.
    |
    prop arguments :? List<EXPRESSION> ;

end
