import org.openehr:representation;

|
| A call made to a 'closed' agent, i.e. one with no remaining open arguments.
|
abstract class EL_AGENT_CALL

feature_group ("access")

    |
    | The agent being called.
    |
    prop agent : EL_AGENT ;

end
