import org.openehr:representation;

|
| An agent whose signature is of a function, i.e. has a result type.
|
class EL_FUNCTION_AGENT
    is_a EL_AGENT

feature_group ("access")

    |
    | Reference to definition of a routine for which this is a function agent.
    |
    prop definition :? BMM_FUNCTION ;

    |
    | Eval type is the function type signature.
    |
    func eval_type : BMM_FUNCTION_TYPE ;

end
