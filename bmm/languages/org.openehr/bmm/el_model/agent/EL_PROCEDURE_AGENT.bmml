|
| An agent whose signature is of a procedure, i.e. has no result type.
|
class EL_PROCEDURE_AGENT
    is_a EL_AGENT

feature_group ("access")

    |
    | Reference to definition of a routine for which this is a procedure agent.
    |
    prop definition :? BMM_PROCEDURE ;

    |
    | Eval type is the procedure type signature.
    |
    func eval_type : BMM_PROCEDURE_TYPE ;

end
