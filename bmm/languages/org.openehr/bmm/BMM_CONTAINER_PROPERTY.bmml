|
| Meta-type of for properties of linear container type, such as List<T> etc.
|
class BMM_CONTAINER_PROPERTY
    is_a BMM_PROPERTY

feature_group ("access")

    |
    | Cardinality of this container.
    |
    prop cardinality :? Multiplicity_interval ;

    |
    | Declared or inferred static type of the entity.
    |
    prop type : BMM_CONTAINER_TYPE ;

    |
    | Name of this property in form name: ContainerTypeName<>.
    |
    func display_name : String ;

end
