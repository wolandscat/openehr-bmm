|
| Type representing a keyed table of values. V is the value type and K the type
| of the keys.
|
class Hash<K: Ordered, V>
    is_a Container<V>

feature_group ("access")

    |
    | Test for presence of a key.
    |
    func has_key : Boolean ;

    |
    | Return item for key.
    |
    func item : V ;

end
